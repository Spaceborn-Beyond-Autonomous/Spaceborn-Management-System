# React Server Port
PORT=3000

# Backend API URL
REACT_APP_API_URL=http://localhost:5000/api

# Frontend URL
REACT_APP_FRONTEND_URL=http://localhost:3000

# Authentication Mode (Set to true to use mock auth without backend database)
REACT_APP_USE_MOCK_AUTH=false

# Google OAuth Configuration
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Session Settings (optional)
REACT_APP_SESSION_TIMEOUT=28800000 # 8 hours in milliseconds
REACT_APP_TOKEN_REFRESH_THRESHOLD=3600000 # 1 hour in milliseconds
REACT_APP_MAX_LOGIN_ATTEMPTS=5
REACT_APP_LOCKOUT_DURATION=900000 # 15 minutes in milliseconds
